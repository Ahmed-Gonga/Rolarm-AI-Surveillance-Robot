[Unit]
Description=Sleep Safe Robot Raspberry Pi Server
After=network.target

[Service]
WorkingDirectory=/home/pi/sleep_safe_robot_full
ExecStart=/home/pi/sleep_safe_robot_full/.venv/bin/python /home/pi/sleep_safe_robot_full/main.py
Restart=always
User=pi
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
